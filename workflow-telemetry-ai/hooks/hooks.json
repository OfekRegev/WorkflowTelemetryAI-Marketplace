{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/workflowTelemetryAI.js", "hook", "session-start"]
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/workflowTelemetryAI.js", "hook", "session-end"]
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "ascii-palette-mixer",
        "hooks": [
          {
            "type": "command",
            "command": "cat",
            "args": ["${CLAUDE_PLUGIN_ROOT}/skills/test-skill/CLAUDE.md"],
            "statusMessage": "Loading telemetry protocol..."
          }
        ]
      }
    ]
  }
}
